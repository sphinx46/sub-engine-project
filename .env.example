# ============================================
# SubEngine - Development Environment Variables
# ============================================
# This file contains examples of all environment variables
# required for local development of the SubEngine project.
# Copy this file to .env.dev and fill in your own values.

# --------------------------------------------
# Service Ports
# Ports on which microservices will run
# --------------------------------------------
EUREKA_SERVER_PORT=8761
API_GATEWAY_PORT=8084
SUBSCRIPTION_SERVICE_PORT=8082
BILLING_SERVICE_PORT=8081
WORKER_SERVICE_PORT=8083

# --------------------------------------------
# Database Ports
# Ports for accessing databases from outside Docker
# --------------------------------------------
KEYCLOAK_DB_PORT=5431
SUBSCRIPTION_DB_PORT=5434
BILLING_DB_PORT=5433
MONGODB_PORT=27017

# --------------------------------------------
# Database Credentials
# Credentials for all project databases
# In production, use strong passwords!
# --------------------------------------------

# Keycloak Database
KEYCLOAK_DB_USERNAME=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_DB_NAME=keycloak

# Subscription Service Database
SUBSCRIPTION_DB_USERNAME=subscription
SUBSCRIPTION_DB_PASSWORD=subscription
SUBSCRIPTION_DB_NAME=subscription

# Billing Service Database
BILLING_DB_USERNAME=billing
BILLING_DB_PASSWORD=billing
BILLING_DB_NAME=billing

# MongoDB for Worker Service (does not require separate authentication)
# MongoDB runs without a password by default in dev environment

# --------------------------------------------
# Keycloak Configuration
# Keycloak authentication settings
# --------------------------------------------

# Keycloak admin credentials
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Realm settings
KEYCLOAK_REALM=sub-engine
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# URI for token validation (inside Docker network)
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/sub-engine

# For browser access, use:
# KEYCLOAK_EXTERNAL_URL=http://localhost:8080

# --------------------------------------------
# JWT Configuration
# Key for signing JWT tokens
# In production, use a generated key!
# --------------------------------------------
SIGNATURE_KEY_SECRET=your-256-bit-secret-key-for-jwt-signature

# How to generate a secure key:
# openssl rand -base64 32
# Example: M7UKlYqX3rT5nB8vC2eF4gH6jI8kL0mN1oP3qR5sT7v

# --------------------------------------------
# Kafka Configuration
# Settings for Kafka in KRaft mode (without ZooKeeper)
# --------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_KRAFT_MODE=true
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# --------------------------------------------
# Spring Profiles
# Active Spring Boot profile
# --------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# Other available profiles:
# prod - production configuration
# test - for running tests
# staging - staging environment

# --------------------------------------------
# Monitoring Ports
# Ports for monitoring tools
# --------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
SUBSCRIPTION_EXPORTER_PORT=9187
BILLING_EXPORTER_PORT=9188

# --------------------------------------------
# JVM Options
# Java Virtual Machine parameters
# --------------------------------------------
JAVA_OPTS=-Xms256m -Xmx512m

# For production, it's recommended:
# JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# --------------------------------------------
# Redis Configuration
# Caching settings
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# For production, always set a password!

# --------------------------------------------
# YooKassa Configuration (Test Mode)
# YooKassa payment system settings
# Test data is used for development
# --------------------------------------------

# Shop ID (test)
YOOKASSA_SHOP_ID=1294580

# Secret key (test)
YOOKASSA_SECRET_KEY=test_VcdN8Xzkn_Hs4LI-L4aVe8-ejvxw82kG6AQyhFsmaaQ

# Return URL after payment
YOOKASSA_RETURN_URL=http://localhost:8084/api/billing/return

# Webhook URL for payment notifications
# For local development, use ngrok or similar service
YOOKASSA_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/api/billing/webhook/yookassa

# --------------------------------------------
# Email Configuration (Development)
# Email sending settings via MailDev
# --------------------------------------------
MAIL_HOST=maildev
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@subengine.com
MAIL_FROM_NAME=SubEngine

# --------------------------------------------
# External Services URLs
# URLs of external services inside Docker network
# --------------------------------------------
EUREKA_SERVICE_URL=http://eureka-server:8761/eureka/
GRAFANA_URL=http://grafana:3000
PROMETHEUS_URL=http://prometheus:9090

# --------------------------------------------
# Logging Configuration
# Logging settings
# --------------------------------------------
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SUBENGINE=DEBUG
# For production, use WARN or ERROR

# --------------------------------------------
# Metrics and Tracing
# Metrics and tracing settings
# --------------------------------------------
MANAGEMENT_TRACING_ENABLED=false
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# --------------------------------------------
# CORS Configuration
# CORS settings for API Gateway
# --------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# --------------------------------------------
# Rate Limiting
# Request rate limiting settings
# --------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_RATE=10

# ============================================
# Setup Instructions
# ============================================

# 1. Copy the file:
#    cp .env.example .env.dev
#
# 2. Edit .env.dev, replacing default values:
#    - KEYCLOAK_CLIENT_SECRET
#    - SIGNATURE_KEY_SECRET
#    - Database passwords (for production)
#
# 3. For local development with YooKassa:
#    - Install ngrok: https://ngrok.com/
#    - Run: ngrok http 8084
#    - Copy the HTTPS URL to YOOKASSA_WEBHOOK_URL
#
# 4. For production, you MUST:
#    - Use generated passwords
#    - Set REDIS_PASSWORD
#    - Configure SSL/TLS
#    - Change profile to SPRING_PROFILES_ACTIVE=prod